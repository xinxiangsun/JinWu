msgid "a0"
msgstr "a0"

#: jinwu.background.backprior.BackgroundSpectralPrior:-1 of
msgid "np.ndarray (n_chan,)"
msgstr "np.ndarray (n_chan,)"

#: jinwu.background.backprior.BackgroundSpectralPrior:11 of
msgid "每个选择能道的先验 shape。"
msgstr "每个选择能道的先验 shape。"

#: jinwu.background.backprior.BackgroundSpectralPrior:12 of
msgid "b0"
msgstr "b0"

#: jinwu.background.backprior.BackgroundSpectralPrior:-1 of
msgid "float"
msgstr "float"

#: jinwu.background.backprior.BackgroundSpectralPrior:13 of
msgid "先验 rate（秒），通常为背景文件中的 EXPOSURE（如 1e6 s）。"
msgstr "先验 rate（秒），通常为背景文件中的 EXPOSURE（如 1e6 s）。"

#: jinwu.background.backprior.BackgroundSpectralPrior:14 of
msgid "area_ratio"
msgstr "area_ratio"

#: jinwu.background.backprior.BackgroundSpectralPrior:15 of
msgid "A_on / A_off。"
msgstr "A_on / A_off。"

#: jinwu.background.backprior.BackgroundSpectralPrior:16 of
msgid "channels"
msgstr "channels"

#: jinwu.background.backprior.BackgroundSpectralPrior:17 of
msgid "参与先验的 CHANNEL 索引集合（用于与观测谱对齐/筛选）。"
msgstr "参与先验的 CHANNEL 索引集合（用于与观测谱对齐/筛选）。"

