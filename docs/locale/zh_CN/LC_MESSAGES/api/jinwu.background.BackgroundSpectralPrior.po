#: jinwu.background.backprior.BackgroundSpectralPrior.from_epwxt_background:3
#: of
msgid ""
"若提供 ARF，则用 SPECRESP 的第 [arf_bin_lo, arf_bin_hi]（1-based）能道推断能段， 并用 "
"EBOUNDS 做能段重合筛选；否则回退到 CHANNEL 区间 [chan_lo, chan_hi]。 OFF/ON 区域面积由像元尺寸及 "
"FoV 计算得到，area_ratio=A_on/A_off。"
msgstr ""
"若提供 ARF，则用 SPECRESP 的第 [arf_bin_lo, arf_bin_hi]（1-based）能道推断能段， 并用 "
"EBOUNDS 做能段重合筛选；否则回退到 CHANNEL 区间 [chan_lo, chan_hi]。 OFF/ON 区域面积由像元尺寸及 "
"FoV 计算得到，area_ratio=A_on/A_off。"

#: jinwu.background.backprior.BackgroundSpectralPrior.update_with_off_spectrum:3
#: of
msgid "若 use_ebounds=True，优先用 EBOUNDS 与 self.channels 对齐；否则按 CHANNEL 匹配。"
msgstr "若 use_ebounds=True，优先用 EBOUNDS 与 self.channels 对齐；否则按 CHANNEL 匹配。"

#: jinwu.background.backprior.BackgroundSpectralPrior.update_with_off_spectrum:4
#: of
msgid "曝光时间从 PHA 的 SPECTRUM header['EXPOSURE'] 读取。"
msgstr "曝光时间从 PHA 的 SPECTRUM header['EXPOSURE'] 读取。"

#: jinwu.background.backprior.BackgroundSpectralPrior.update_with_off_spectrum:5
#: of
msgid ""
"返回 BackgroundCountsPosterior，参数 "
"a_total=sum(a0)+sum(n_off_obs)，b=b0+t_off_obs。"
msgstr ""
"返回 BackgroundCountsPosterior，参数 "
"a_total=sum(a0)+sum(n_off_obs)，b=b0+t_off_obs。"
