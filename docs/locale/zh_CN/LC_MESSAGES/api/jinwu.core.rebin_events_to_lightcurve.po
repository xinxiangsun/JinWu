msgid "输入事件数据"
msgstr "输入事件数据"

#: jinwu.core.ops.rebin_events_to_lightcurve:9 of
msgid "binsize"
msgstr "binsize"

#: jinwu.core.ops.rebin_events_to_lightcurve:-1 of
msgid "float"
msgstr "float"

