#: ../../api/jinwu.core.rebin_events_to_lightcurve.rst:2
msgid "rebin_events_to_lightcurve"
msgstr "事例重分箱为光变曲线"

#: jinwu.core.ops.rebin_events_to_lightcurve:1 of
msgid "从事件数据生成分 bin 光变曲线。"
msgstr "从事件数据生成分 bin 光变曲线。"

#: jinwu.core.ops.rebin_events_to_lightcurve:3 of
msgid "将事件列表按时间分组统计，生成光变曲线。"
msgstr "将事件列表按时间分组统计，生成光变曲线。"

