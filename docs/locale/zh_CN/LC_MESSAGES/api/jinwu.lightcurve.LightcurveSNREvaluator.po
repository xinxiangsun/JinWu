msgstr "判定光变曲线在 T0 之后 window 秒内是否能达到目标 SNR。"

#: ../../api/jinwu.lightcurve.LightcurveSNREvaluator.rst:18
msgid "Methods Documentation"
msgstr "方法文档"

#: jinwu.lightcurve.duration.LightcurveSNREvaluator of
msgid "Parameters"
msgstr "参数"

#: jinwu.lightcurve.duration.LightcurveSNREvaluator.from_counts:3 of
msgid ""
"1D array of time stamps corresponding to each bin. If these are left "
"edges, dt must be provided; if these are centers and dt is not given, it "
"will be inferred from median spacing."
msgstr ""
"与每 bin 对应的时间戳 1D 数组。若为左边界，则必须提供 dt；若为中心且未提供 dt，"
"则从中位间距推断。"

#: jinwu.lightcurve.duration.LightcurveSNREvaluator.from_counts:7 of
msgid "1D array of ON-region counts per bin (non-negative)."
msgstr "ON 区域每 bin 计数的 1D 数组（非负）。"

#: jinwu.lightcurve.duration.LightcurveSNREvaluator.from_counts:9 of
msgid "Bin width in seconds. If None, inferred as median diff of time."
msgstr "bin 宽度（秒）。若为 None，则从时间的中位差推断。"

#: jinwu.lightcurve.duration.LightcurveSNREvaluator.from_counts:11 of
msgid "Background prior object."
msgstr "背景先验对象。"

#: jinwu.lightcurve.duration.LightcurveSNREvaluator.from_npz:3 of
msgid ""
"Selection logic: - time = npz[time_key_primary] if present else "
"npz[time_key_fallback] - counts (ON region per bin):"
msgstr "选择逻辑： - time = npz[time_key_primary]（若存在）否则 npz[time_key_fallback] - counts（ON 区域每 bin）："

#: jinwu.lightcurve.duration.LightcurveSNREvaluator.from_npz:6 of
msgid "if counts_key_preferred in npz: use it directly"
msgstr "若 counts_key_preferred 存在于 npz：直接使用"

#: jinwu.lightcurve.duration.LightcurveSNREvaluator.from_npz:7 of
msgid ""
"elif both net_key and off_key in npz: reconstruct ON counts as counts_on "
"= net + background.area_ratio * off"
msgstr ""
"否则若 net_key 和 off_key 均存在于 npz：按 counts_on = net + background.area_ratio * off 重建 ON 计数"

#: jinwu.lightcurve.duration.LightcurveSNREvaluator.from_npz:9 of
msgid "elif raw_counts_key_fallback in npz: use it as counts (warning)"
msgstr "否则若 raw_counts_key_fallback 存在于 npz：将其用作计数（警告）"

#: jinwu.lightcurve.duration.LightcurveSNREvaluator.from_npz:10 of
msgid "else: raise ValueError"
msgstr "否则：抛出 ValueError"

#: jinwu.lightcurve.duration.LightcurveSNREvaluator.from_npz:12 of
msgid "Path to NPZ file with lightcurve arrays."
msgstr "包含光变曲线数组的 NPZ 文件路径。"

#: jinwu.lightcurve.duration.LightcurveSNREvaluator.from_npz:14 of
msgid "Background prior object (provides area_ratio for reconstruction)."
msgstr "背景先验对象（提供 area_ratio 用于重建）。"

#: jinwu.lightcurve.duration.LightcurveSNREvaluator.from_npz:16 of
msgid "Bin width; if None, inferred from median diff of the chosen time array."
msgstr "bin 宽度；若为 None，则从所选时间数组的中位差推断。"

#: jinwu.lightcurve.duration.LightcurveSNREvaluator.from_npz:18 of
msgid "If True, prints brief notes about which keys were used."
msgstr "若为 True，打印关于使用了哪些键的简要说明。"

#: jinwu.lightcurve.duration.LightcurveSNREvaluator.reaches_snr:4 of
msgid "Target SNR threshold (default 7.0)."
msgstr "目标 SNR 阈值（默认 7.0）。"

#: jinwu.lightcurve.duration.LightcurveSNREvaluator.reaches_snr:6 of
msgid "Time window in seconds after T0 to search for max SNR (default 1200 s)."
msgstr "T0 之后搜索最大 SNR 的时间窗口（秒，默认 1200 秒）。"

#: jinwu.lightcurve.duration.LightcurveSNREvaluator.reaches_snr:8 of
msgid ""
"- 'fast': use expected OFF counts (no Poisson sampling), deterministic. -"
" 'mc': Monte Carlo sampling with Poisson fluctuations for ON and OFF."
msgstr ""
"- 'fast': 使用期望 OFF 计数（无泊松采样），确定性。 - 'mc': 对 ON 和 OFF 进行带泊松涨落的蒙特卡洛采样。"

#: jinwu.lightcurve.duration.LightcurveSNREvaluator.reaches_snr:9 of
msgid "'fast': use expected OFF counts (no Poisson sampling), deterministic."
msgstr "'fast': 使用期望 OFF 计数（无泊松采样），确定性。"

#: jinwu.lightcurve.duration.LightcurveSNREvaluator.reaches_snr:10 of
msgid "'mc': Monte Carlo sampling with Poisson fluctuations for ON and OFF."
msgstr "'mc': 对 ON 和 OFF 进行带泊松涨落的蒙特卡洛采样。"

#: jinwu.lightcurve.duration.LightcurveSNREvaluator.reaches_snr:12 of
msgid "Number of MC replicates when mode='mc'."
msgstr "mode='mc' 时的 MC 重复次数。"

#: jinwu.lightcurve.duration.LightcurveSNREvaluator.reaches_snr:14 of
msgid "Random generator for MC."
msgstr "MC 随机数生成器。"

#: jinwu.lightcurve.duration.LightcurveSNREvaluator.reaches_snr:16 of
msgid "SNR threshold used for T0 detection (default 3.0)."
msgstr "用于 T0 检测的 SNR 阈值（默认 3.0）。"

#: jinwu.lightcurve.duration.LightcurveSNREvaluator.reaches_snr:18 of
msgid "OFF counts treatment for both T0 and window SNR. See _find_T0_by_blocks."
msgstr "T0 和窗口 SNR 的 OFF 计数处理方式。参见 _find_T0_by_blocks。"

#: jinwu.lightcurve.duration.LightcurveSNREvaluator of
msgid "Returns"
msgstr "返回"

#: jinwu.lightcurve.duration.LightcurveSNREvaluator.reaches_snr:21 of
msgid ""
"- bool: True if probability (fast: indicator) of reaching target SNR   is"
" >= 0.95 (only meaningful for mc; for fast it is True/False as is). - "
"dict: diagnostics including T0 estimate, probability (for mc),   and "
"optionally the distribution of max SNRs."
msgstr ""
"- bool: 若达到目标 SNR 的概率（fast：指示器）>= 0.95 则为 True（仅对 mc 有意义；"
"fast 模式下按 True/False 直接返回）。 - dict: 诊断信息，包括 T0 估计、概率（mc 模式）"
"以及可选的 max SNR 分布。"

#: jinwu.lightcurve.duration.LightcurveSNREvaluator.reaches_snr:23 of
msgid ""
"bool: True if probability (fast: indicator) of reaching target SNR is >= "
"0.95 (only meaningful for mc; for fast it is True/False as is)."
msgstr ""
"bool: 若达到目标 SNR 的概率（fast：指示器）>= 0.95 则为 True（仅对 mc 有意义；"
"fast 模式下按 True/False 直接返回）。"

#: jinwu.lightcurve.duration.LightcurveSNREvaluator.reaches_snr:25 of
msgid ""
"dict: diagnostics including T0 estimate, probability (for mc), and "
"optionally the distribution of max SNRs."
msgstr "dict: 诊断信息，包括 T0 估计、概率（mc 模式）以及可选的 max SNR 分布。"

#: jinwu.lightcurve.duration.LightcurveSNREvaluator of
msgid "Return type"
msgstr "返回类型"
