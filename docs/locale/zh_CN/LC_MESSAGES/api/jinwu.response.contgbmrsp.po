msgstr "获取开始时间(Fermi MET)。"

#: jinwu.response.gbm.contgbmrsp:13 of
msgid "获取结束时间(Fermi MET)。"
msgstr "获取结束时间(Fermi MET)。"

#: jinwu.response.gbm.contgbmrsp:14 of
msgid "获取从探测器代号派生的探测器编号。"
msgstr "获取从探测器代号派生的探测器编号。"

#: jinwu.response.gbm.contgbmrsp:15 of
msgid "获取探测器代号。"
msgstr "获取探测器代号。"

#: jinwu.response.gbm.contgbmrsp:16 of
