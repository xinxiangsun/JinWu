#: ../../api/jinwu.response.contgbmrsp.rst:2
msgid "contgbmrsp"
msgstr "GBM连续响应"

#: jinwu.response.gbm.contgbmrsp:1 of
msgid ""
"用来生成连续观测的 GBM 响应文件，针对非触发情形。 需要通过网页安装的 GBM 响应生成的 Perl "
"程序，并且所有的数据应该满足特定的文件目录格式。"
msgstr ""
"用来生成连续观测的 GBM 响应文件，针对非触发情形。 需要通过网页安装的 GBM 响应生成的 Perl "
"程序，并且所有的数据应该满足特定的文件目录格式。"

#: jinwu.response.gbm.contgbmrsp:3 of
msgid "赤经，单位是度，天文坐标系下的坐标。"
msgstr "赤经，单位是度，天文坐标系下的坐标。"

#: jinwu.response.gbm.contgbmrsp:4 of
msgid "赤纬，单位是度，天文坐标系下的坐标。"
msgstr "赤纬，单位是度，天文坐标系下的坐标。"

#: jinwu.response.gbm.contgbmrsp:5 of
msgid "开始时间, Fermi MET 时间，以秒为单位。"
msgstr "开始时间, Fermi MET 时间，以秒为单位。"

#: jinwu.response.gbm.contgbmrsp:6 of
msgid "结束时间, Fermi MET 时间，以秒为单位。"
msgstr "结束时间, Fermi MET 时间，以秒为单位。"

#: jinwu.response.gbm.contgbmrsp:7 of
msgid "探测器代号列表。"
msgstr "探测器代号列表。"

#: jinwu.response.gbm.contgbmrsp:8 of
msgid "生成用于执行 GBM 响应生成的 Perl 脚本的命令字符串。 执行生成的命令字符串，并打印输出或错误信息。"
msgstr "生成用于执行 GBM 响应生成的 Perl 脚本的命令字符串。 执行生成的命令字符串，并打印输出或错误信息。"

#: jinwu.response.gbm.contgbmrsp:10 of
msgid "获取赤经。"
msgstr "获取赤经。"

