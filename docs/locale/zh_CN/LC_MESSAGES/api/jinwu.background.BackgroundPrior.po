#: ../../api/jinwu.background.BackgroundPrior.rst:2
msgid "BackgroundPrior"
msgstr "背景先验"

#: jinwu.background.backprior.BackgroundPrior:1 of
msgid "Background prior based on OFF-region total counts over a known exposure."
msgstr "基于已知曝光时间内 OFF 区域总计数的背景先验。"

#: jinwu.background.backprior.BackgroundPrior:5 of
msgid "Total counts observed in the OFF region during t_off seconds."
msgstr "在 t_off 秒内于 OFF 区域观测到的总计数。"

#: jinwu.background.backprior.BackgroundPrior of
msgid "type"
msgstr "类型"

#: jinwu.background.backprior.BackgroundPrior:7
#: jinwu.background.backprior.BackgroundPrior:13
#: jinwu.background.backprior.BackgroundPrior:19 of
msgid "float"
msgstr "float"

#: jinwu.background.backprior.BackgroundPrior:11 of
msgid "Exposure time in the OFF region corresponding to n_off_prior (seconds)."
msgstr "与 n_off_prior 对应的 OFF 区域曝光时间（秒）。"

#: jinwu.background.backprior.BackgroundPrior:17 of
msgid "A_on / A_off. The Li&Ma alpha uses alpha = area_ratio * (t_on / t_off)."
msgstr "A_on / A_off。Li&Ma 的 alpha 参数使用 alpha = area_ratio * (t_on / t_off)。"

#: ../../api/jinwu.background.BackgroundPrior.rst:10
msgid "Methods Summary"
msgstr "方法概要"

#: ../../api/jinwu.background.BackgroundPrior.rst:16:<autosummary>:1
msgid ":py:obj:`alpha <jinwu.background.BackgroundPrior.alpha>`\\ \\(t\\_on\\)"
msgstr ":py:obj:`alpha <jinwu.background.BackgroundPrior.alpha>`\\ \\(t\\_on\\)"

#: ../../api/jinwu.background.BackgroundPrior.rst:16:<autosummary>:1
msgid ""
":py:obj:`from_epwxt_background "
"<jinwu.background.BackgroundPrior.from_epwxt_background>`\\ "
"\\(fits\\_path\\, \\*\\[\\, ...\\]\\)"
msgstr ""
":py:obj:`from_epwxt_background "
"<jinwu.background.BackgroundPrior.from_epwxt_background>`\\ "
"\\(fits\\_path\\, \\*\\[\\, ...\\]\\)"

#: ../../api/jinwu.background.BackgroundPrior.rst:16:<autosummary>:1
#: jinwu.background.backprior.BackgroundPrior.from_epwxt_background:1 of
msgid ""
"Construct BackgroundPrior from a single EP/WXT background FITS file that "
"contains counts per cm^2 accumulated over a reference exposure (typically"
" 1e6 s)."
msgstr ""
"从单个 EP/WXT 背景 FITS 文件构造 BackgroundPrior，该文件包含在参考曝光时间（通常为 1e6 "
"秒）内每平方厘米的累计计数。"

#: ../../api/jinwu.background.BackgroundPrior.rst:16:<autosummary>:1
msgid ""
":py:obj:`from_epwxt_background_default "
"<jinwu.background.BackgroundPrior.from_epwxt_background_default>`\\ "
"\\(\\*\\[\\, chan\\_lo\\, ...\\]\\)"
msgstr ""
":py:obj:`from_epwxt_background_default "
"<jinwu.background.BackgroundPrior.from_epwxt_background_default>`\\ "
"\\(\\*\\[\\, chan\\_lo\\, ...\\]\\)"

#: ../../api/jinwu.background.BackgroundPrior.rst:16:<autosummary>:1
msgid "Return the ready-made BackgroundPrior values as requested by user."
msgstr "返回用户请求的现成 BackgroundPrior 值。"

#: ../../api/jinwu.background.BackgroundPrior.rst:18
msgid "Methods Documentation"
msgstr "方法文档"

#: jinwu.background.backprior.BackgroundPrior.from_epwxt_background:4 of
msgid ""
"This enforces the energy band via detector channels [chan_lo, chan_hi] "
"(default 53–506, about 0.5–4.0 keV), computes the OFF-region prior counts"
" in a desired t_off, and derives area_ratio from instrument geometry."
msgstr ""
"通过探测器通道 [chan_lo, chan_hi]（默认 53–506，约 0.5–4.0 keV）限定能段，"
"计算所需 t_off 内的 OFF 区域先验计数，并根据仪器几何推导 area_ratio。"

#: ../../api/jinwu.background.BackgroundPrior.rst
msgid "Parameters"
msgstr "参数"

#: jinwu.background.backprior.BackgroundPrior.from_epwxt_background:8 of
msgid ""
"Path to the background FITS (counts per cm^2). In practice only one "
"combined background file is available."
msgstr "背景 FITS 文件路径（每平方厘米计数）。实际中只有一个合并的背景文件可用。"

#: jinwu.background.backprior.BackgroundPrior.from_epwxt_background:11
#: jinwu.background.backprior.BackgroundPrior.from_epwxt_background:13 of
msgid "Inclusive channel bounds to approximate 0.5–4.0 keV."
msgstr "含上下界的通道范围，用于近似 0.5–4.0 keV 能段。"

#: jinwu.background.backprior.BackgroundPrior.from_epwxt_background:15 of
msgid "Pixel size on detector (mm). Default 0.015 mm."
msgstr "探测器像元尺寸（mm）。默认 0.015 mm。"

#: jinwu.background.backprior.BackgroundPrior.from_epwxt_background:17 of
msgid "Sky angular size per pixel (degree). Default 0.00229 deg."
msgstr "每像元的天球角尺寸（度）。默认 0.00229 度。"

#: jinwu.background.backprior.BackgroundPrior.from_epwxt_background:19 of
msgid "Source region radius (arcmin). Default 9'."
msgstr "源区域半径（角分）。默认 9'。"

#: jinwu.background.backprior.BackgroundPrior.from_epwxt_background:21
#: jinwu.background.backprior.BackgroundPrior.from_epwxt_background:23 of
msgid "Background annulus inner/outer radii (arcmin). Default 18'–36'."
msgstr "背景环带内/外半径（角分）。默认 18'–36'。"

#: jinwu.background.backprior.BackgroundPrior.from_epwxt_background:25 of
msgid "OFF prior exposure (s) for Li&Ma. Default 1e6 s (matches FITS by default)."
msgstr "Li&Ma 的 OFF 先验曝光时间（秒）。默认 1e6 秒（与 FITS 文件默认匹配）。"

#: jinwu.background.backprior.BackgroundPrior.from_epwxt_background:27 of
msgid "Print brief diagnostics."
msgstr "打印简要诊断信息。"

#: ../../api/jinwu.background.BackgroundPrior.rst
msgid "Return type"
msgstr "返回类型"

#: jinwu.background.backprior.BackgroundPrior.from_epwxt_background_default:1
#: of
msgid ""
"Return the ready-made BackgroundPrior values as requested by user. "
"Ignores file IO and outputs fixed values for reproducibility of quick "
"tests."
msgstr ""
"返回用户请求的现成 BackgroundPrior 值。忽略文件 IO，输出固定值以保证快速测试的可复现性。"
