#: ../../api/jinwu.lightcurve.TriggerDecider.rst:2
msgid "TriggerDecider"
msgstr ""

#: jinwu.lightcurve.trigger.TriggerDecider:1 of
msgid "Decide triggerability from a counts lightcurve or event times."
msgstr ""

#: jinwu.lightcurve.trigger.TriggerDecider:4 of
msgid "Core checks"
msgstr ""

#: jinwu.lightcurve.trigger.TriggerDecider:5 of
msgid ""
"sliding_window(window=1200): scan max Li&Ma SNR over all windows of size "
"window."
msgstr ""

#: jinwu.lightcurve.trigger.TriggerDecider:6 of
msgid "head_window(window=1200): Li&Ma SNR of the first window only."
msgstr ""

#: jinwu.lightcurve.trigger.TriggerDecider:7 of
msgid ""
"cumulative_from_t0(target=7): if head window fails, grow cumulatively "
"from T0 (by default first non-zero bin) and check if SNR reaches target."
msgstr ""

#: jinwu.lightcurve.trigger.TriggerDecider:11 of
msgid "Inputs"
msgstr ""

#: jinwu.lightcurve.trigger.TriggerDecider:12 of
msgid ""
"time : 1D array of bin left edges or centers (monotonic increasing) "
"counts : 1D array of ON-region counts per bin (non-negative) dt : float "
"bin width in seconds (assumed constant) bg : BackgroundSimple with "
"(n_off_ref, t_off_ref, area_ratio)"
msgstr ""

#: jinwu.lightcurve.trigger.TriggerDecider:18 of
msgid "Notes"
msgstr ""

#: jinwu.lightcurve.trigger.TriggerDecider:19 of
msgid ""
"This class does not alter the counts (no Poissonization). Future MC can "
"be added by drawing per-bin ON counts around an expectation and reusing "
"the same APIs."
msgstr ""

