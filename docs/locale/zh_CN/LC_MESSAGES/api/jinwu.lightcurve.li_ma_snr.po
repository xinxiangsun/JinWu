#: ../../api/jinwu.lightcurve.li_ma_snr.rst:2
msgid "li_ma_snr"
msgstr "Li-Ma信噪比"

#: jinwu.lightcurve.duration.li_ma_snr:1 of
msgid ""
"Compute Li & Ma significance (Eq. 17 in Li & Ma 1983) given counts and "
"alpha."
msgstr ""
"根据计数和 alpha 计算 Li & Ma 显著性（Li & Ma 1983 中的公式 17）。"

#: ../../api/jinwu.lightcurve.li_ma_snr.rst
msgid "Parameters"
msgstr "参数"

#: jinwu.lightcurve.duration.li_ma_snr:3 of
msgid "Total counts in ON region."
msgstr "ON 区域的总计数。"

#: jinwu.lightcurve.duration.li_ma_snr:5 of
msgid "Total counts in OFF region (reference background)."
msgstr "OFF 区域的总计数（参考背景）。"

#: jinwu.lightcurve.duration.li_ma_snr:7 of
msgid ""
"Exposure/area scaling factor from OFF to ON: alpha = "
"(A_on/A_off)*(t_on/t_off)."
msgstr ""
"从 OFF 到 ON 的曝光/面积缩放因子：alpha = (A_on/A_off)*(t_on/t_off)。"

#: ../../api/jinwu.lightcurve.li_ma_snr.rst
msgid "Returns"
msgstr "返回"

#: jinwu.lightcurve.duration.li_ma_snr:10 of
msgid "The Li & Ma significance (>=0). Returns 0.0 if inputs are degenerate."
msgstr "Li & Ma 显著性（>=0）。若输入退化则返回 0.0。"

#: ../../api/jinwu.lightcurve.li_ma_snr.rst
msgid "Return type"
msgstr "返回类型"
