#: ../../api/jinwu.background.BackgroundCountsPosterior.rst:2
msgid "BackgroundCountsPosterior"
msgstr ""

#: jinwu.background.backprior.BackgroundCountsPosterior:1 of
msgid "背景区域计数后验（聚合到选择能段之后）。"
msgstr ""

#: jinwu.background.backprior.BackgroundCountsPosterior:3 of
msgid ""
"基于 Gamma-Poisson 共轭：以 OFF 区域“计数率” λ_off ~ Gamma(a_total, b) "
"（shape=a_total, rate=b），则： - OFF 区域在曝光 t 的后验预测 n_off ~ Poisson-Gamma "
"混合，等价于 NB(r=a_total, p=b/(b+t))； - ON 区域在曝光 t 的后验预测 n_on,bkg ~ "
"NB(r=a_total, p=b/(b+area_ratio*t))，"
msgstr ""

#: jinwu.background.backprior.BackgroundCountsPosterior:7 of
msgid "其中 area_ratio=A_on/A_off。"
msgstr ""

#: jinwu.background.backprior.BackgroundCountsPosterior:9 of
msgid "我们通过 Gamma-Poisson 的层次采样实现采样（避免不同库对 NB 参数化差异）。"
msgstr ""

#: jinwu.background.backprior.BackgroundCountsPosterior:12 of
msgid "属性"
msgstr ""

#: jinwu.background.backprior.BackgroundCountsPosterior:13 of
msgid "a_total"
msgstr ""

#: jinwu.background.backprior.BackgroundCountsPosterior:-1 of
msgid "float"
msgstr ""

#: jinwu.background.backprior.BackgroundCountsPosterior:14 of
msgid "选择能段内所有能道的先验 shape 之和（更新后为后验 shape）。"
msgstr ""

#: jinwu.background.backprior.BackgroundCountsPosterior:15 of
msgid "b"
msgstr ""

#: jinwu.background.backprior.BackgroundCountsPosterior:16 of
msgid "先验/后验的 rate 参数（单位：秒），通常为 t_ref + sum(t_obs_off)。"
msgstr ""

#: jinwu.background.backprior.BackgroundCountsPosterior:17 of
msgid "area_ratio"
msgstr ""

#: jinwu.background.backprior.BackgroundCountsPosterior:18 of
msgid "A_on / A_off，用于把 OFF 计数率映射到 ON 背景计数率。"
msgstr ""

